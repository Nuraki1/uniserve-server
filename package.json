{
  "name": "restaurantinternal-server",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-htaccess.cjs",
    "server": "node dist/index.js",
    "prisma:generatee": "prisma generate",
    "prisma:migratee": "prisma migrate deploy",
    "prisma:migrate:deve": "prisma migrate dev",
    "prisma:pushe": "prisma db push",
    "prisma:generate": "node scripts/ensure-env.cjs && npx --yes prisma@^5.22.0 generate",
    "prisma:migrate": "node scripts/ensure-env.cjs && npx --yes prisma@^5.22.0 migrate deploy",
    "prisma:migrate:dev": "node scripts/ensure-env.cjs && npx --yes prisma@^5.22.0 migrate dev",
    "prisma:push": "node scripts/ensure-env.cjs && npx --yes prisma@^5.22.0 db push",
    "postinstall": "if [ -f prisma/schema.prisma ]; then npx --yes prisma@^5.22.0 generate; else echo 'Prisma schema not found. Run: npm run prisma:generate'; fi"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.30",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}




